{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!docs/**",
        "!.turbo/**",
        "!.next/**",
        "!dist/**",
        "!build/**",
        "!coverage/**",
        "!pkg/**",
        "!target/**",
        "!*.node",
        "!*.tsbuildinfo"
      ],
      "outputs": ["dist/**", ".next/**", "build/**", "*.node", "index.d.ts"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!docs/**",
        "!.turbo/**",
        "!.next/**",
        "!dist/**",
        "!build/**",
        "!coverage/**",
        "!pkg/**",
        "!target/**",
        "!*.node",
        "!*.tsbuildinfo"
      ]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!docs/**",
        "!.turbo/**",
        "!.next/**",
        "!dist/**",
        "!build/**",
        "!coverage/**",
        "!pkg/**",
        "!target/**",
        "!*.node",
        "!*.tsbuildinfo"
      ]
    },
    "docs": {
      "dependsOn": ["^docs"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!docs/**",
        "!.turbo/**",
        "!.next/**",
        "!dist/**",
        "!build/**",
        "!coverage/**",
        "!pkg/**",
        "!target/**",
        "!*.node",
        "!*.tsbuildinfo"
      ],
      "outputs": ["docs/**"]
    },
    "format:check": {
      "dependsOn": ["^format:check"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!docs/**",
        "!.turbo/**",
        "!.next/**",
        "!dist/**",
        "!build/**",
        "!coverage/**",
        "!pkg/**",
        "!target/**",
        "!*.node",
        "!*.tsbuildinfo"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
