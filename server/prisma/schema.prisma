// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Tenant {
  id                    String                 @id @default(uuid())
  name                  String // Add this
  dailyQuotaStroops     BigInt? // Add this
  totalCredit           Decimal? // Add this
  quotaTopUps           QuotaTopUp[]
  payments              Payment[]
  sponsoredTransactions SponsoredTransaction[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt // Add this
  apiKeys               ApiKey[]
  webhookDeliveries     WebhookDelivery[]
}

model ApiKey {
  id                String   @id @default(uuid())
  key               String   @unique
  prefix            String
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  active            Boolean  @default(true)
  dailyQuotaStroops BigInt   @default(1000000) // 0.1 XLM default
  maxRequests       Int      @default(5)
  windowMs          Int      @default(60000)
  tier              String   @default("free") // free or pro
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model WebhookDelivery {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  url         String
  payload     String
  status      String    @default("pending") // pending, success, failed
  retryCount  Int       @default(0)
  lastError   String?
  nextAttempt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([tenantId])
}

model QuotaTopUp {
  id        Int      @id @default(autoincrement())
  amount    Int
  userId    Int
  user      User     @relation(fields: [userId], references: [id]) // This fixes the second error
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
}

model SupportedAsset {
  id         String   @id @default(uuid())
  code       String
  issuer     String?
  minBalance String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([code, issuer])
}

model SponsoredTransaction {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  feeStroops BigInt
  createdAt  DateTime @default(now())
}

model SignerSecret {
  id                String   @id @default(uuid())
  publicKey         String   @unique
  encryptedSecret   String
  initializationVec String
  authTag           String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model server_configs {
  id           Int      @id @default(autoincrement())
  config_key   String   @unique
  config_value Decimal
  updated_at   DateTime @default(now())
}

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  username String?

  payments    Payment[]
  quotaTopUps QuotaTopUp[]
  createdAt   DateTime     @default(now())
}

model Payment {
  id        Int      @id @default(autoincrement())
  amount    Decimal
  status    String
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  tenantId  String? // Add this
  tenant    Tenant?  @relation(fields: [tenantId], references: [id]) // Add this
  createdAt DateTime @default(now())
}
