{
  "sdks": [
    {
      "id": "typescript",
      "name": "TypeScript SDK",
      "language": "TypeScript",
      "description": "The official XLM Paymaster client for TypeScript and JavaScript. Works in Node.js, browsers, and edge runtimes.",
      "installCommand": "npm install paymaster-client",
      "registry": "npm",
      "packageName": "paymaster-client",
      "docsUrl": "https://docs.xlm-paymaster.com/sdk/typescript",
      "typeDocUrl": "https://docs.xlm-paymaster.com/typedoc/typescript",
      "repoUrl": "https://github.com/Stellar-Paymaster/xlm-paymaster/tree/main/client",
      "latestVersion": "1.3.0",
      "versions": [
        {
          "version": "1.3.0",
          "date": "2026-03-01",
          "changes": [
            "Add `requestFeeBumpBatch` for submitting multiple XDRs in one call",
            "Expose `PaymasterClient.healthCheck()` to ping the server before submitting",
            "Reduce bundle size by 18% via tree-shaking improvements"
          ]
        },
        {
          "version": "1.2.1",
          "date": "2026-01-15",
          "changes": [
            "Fix retry logic not honouring the `maxRetries` option",
            "Correctly pass `networkPassphrase` to fee-bump envelope builder"
          ]
        },
        {
          "version": "1.2.0",
          "date": "2025-11-20",
          "changes": [
            "Add Soroban RPC support via `requestSorobanFeeBump`",
            "New `onRetry` callback for observing retry attempts",
            "Improve error messages with Horizon result codes"
          ]
        },
        {
          "version": "1.1.0",
          "date": "2025-09-08",
          "changes": [
            "Support configurable `timeout` per request",
            "Add `PaymasterError` typed exception with `statusCode` and `code` fields",
            "Publish ESM and CJS builds"
          ]
        }
      ]
    },
    {
      "id": "python",
      "name": "Python SDK",
      "language": "Python",
      "description": "Async-first Python client for the XLM Paymaster API. Built on httpx with full type annotations and Django/FastAPI middleware.",
      "installCommand": "pip install paymaster-py",
      "registry": "pypi",
      "packageName": "paymaster-py",
      "docsUrl": "https://docs.xlm-paymaster.com/sdk/python",
      "typeDocUrl": "https://docs.xlm-paymaster.com/typedoc/python",
      "repoUrl": "https://github.com/Stellar-Paymaster/xlm-paymaster-py",
      "latestVersion": "0.9.2",
      "versions": [
        {
          "version": "0.9.2",
          "date": "2026-02-18",
          "changes": [
            "Fix `PaymasterClient.close()` not awaiting underlying httpx session",
            "Add `py.typed` marker for PEP 561 compatibility"
          ]
        },
        {
          "version": "0.9.0",
          "date": "2026-01-05",
          "changes": [
            "Add async batch endpoint support",
            "Django middleware: auto-inject `request.paymaster_client`",
            "FastAPI dependency helper `get_paymaster_client()`"
          ]
        },
        {
          "version": "0.8.0",
          "date": "2025-10-12",
          "changes": [
            "Initial stable release",
            "Full async/await API with httpx backend",
            "Pydantic v2 response models"
          ]
        }
      ]
    },
    {
      "id": "go",
      "name": "Go SDK",
      "language": "Go",
      "description": "Idiomatic Go client for XLM Paymaster. Thread-safe, context-aware, and compatible with the official Stellar Go SDK.",
      "installCommand": "go get github.com/Stellar-Paymaster/xlm-paymaster-go",
      "registry": "pkg.go.dev",
      "packageName": "github.com/Stellar-Paymaster/xlm-paymaster-go",
      "docsUrl": "https://docs.xlm-paymaster.com/sdk/go",
      "typeDocUrl": "https://pkg.go.dev/github.com/Stellar-Paymaster/xlm-paymaster-go",
      "repoUrl": "https://github.com/Stellar-Paymaster/xlm-paymaster-go",
      "latestVersion": "v0.6.1",
      "versions": [
        {
          "version": "v0.6.1",
          "date": "2026-02-28",
          "changes": [
            "Fix context cancellation not propagating to HTTP round-tripper",
            "Add `WithTimeout` functional option"
          ]
        },
        {
          "version": "v0.6.0",
          "date": "2025-12-10",
          "changes": [
            "Add `Client.FeeBumpBatch()` for batch submissions",
            "Expose `HealthCheck()` method",
            "Improve error wrapping with `%w` for `errors.Is` compatibility"
          ]
        },
        {
          "version": "v0.5.0",
          "date": "2025-09-22",
          "changes": [
            "Initial public release",
            "Thread-safe client with `sync.Mutex` guard",
            "Full context.Context support on all methods"
          ]
        }
      ]
    },
